
target="mingw-w64"
toolchain="toolchain.sh"

pkgs=(
    "sdl2"
    "sdl2_image"
    "glew"
    "glm"
    "vulkan_headers"
    "vulkan_loader")

pkgs=("glm")

toolchain_mingw32="${DIR}/../toolchain/mingw32.cmake"
toolchain_mingw64="${DIR}/../toolchain/mingw64.cmake"

function i686-w64-mingw32-cmake() { 
    cmake -DCMAKE_INSTALL_PREFIX=/usr/i686-w64-mingw32 -DCMAKE_TOOLCHAIN_FILE=${toolchain_mingw32} "$@"
}
function x86_64-w64-mingw32-cmake() {
    cmake -DCMAKE_INSTALL_PREFIX=/usr/x86_64-w64-mingw32 -DCMAKE_TOOLCHAIN_FILE=${toolchain_mingw64} "$@"
}